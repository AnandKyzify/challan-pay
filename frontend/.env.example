# =============================================================================
# Frontend API base URL — read by src/lib/apiBase.ts → used in src/services/api.ts
# =============================================================================

# --- Local development (recommended) ---
# Vite dev server proxies /api → http://127.0.0.1:8000 (see vite.config.ts).
# Same-origin from the browser, so no CORS.
VITE_API_BASE_URL=/api

# Optional: only for SSR during `npm run dev` (defaults to http://127.0.0.1:5173)
# VITE_DEV_SERVER_ORIGIN=http://127.0.0.1:5173

# --- Production on one server / one domain (recommended — no CORS) ---
# Put the UI and API behind nginx (or similar): https://yourdomain.com → frontend,
# https://yourdomain.com/api → backend. Keep a relative path:
# VITE_API_BASE_URL=/api
# VITE_APP_ORIGIN=https://yourdomain.com

# --- Production: API on a different host (requires backend CORS_ORIGINS) ---
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_APP_ORIGIN=https://yourdomain.com
