# Copy to .env.production before `npm run build` (or set in your deploy CI).

# Same domain as the UI (reverse proxy /api → FastAPI) — avoids CORS
VITE_API_BASE_URL=/api
VITE_APP_ORIGIN=https://yourdomain.com

# If API is on another subdomain instead, use full URL and set CORS on the backend:
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_APP_ORIGIN=https://yourdomain.com
