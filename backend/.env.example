# MongoDB (database: pan)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pan

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Default admin (created on first startup if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS — only needed if the UI calls the API on a different origin (full VITE_API_BASE_URL).
# Same-domain deploy with VITE_API_BASE_URL=/api + reverse proxy does not need extra origins.
# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourdomain.com

# App
APP_NAME=Challan CMS API
DEBUG=false
